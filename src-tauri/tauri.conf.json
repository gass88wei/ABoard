{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ABoard",
  "version": "0.1.0",
  "identifier": "com.aboard.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "ABoard",
        "width": 1000,
        "height": 640,
        "resizable": true,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": true,
        "dragDropEnabled": false
      },
      {
        "label": "floating",
        "title": "ABoard Quick Paste",
        "width": 280,
        "height": 520,
        "resizable": false,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "dragDropEnabled": false,
        "url": "/"
      }
    ],
    "security": {
      "csp": "default-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "14.0",
      "infoPlist": "Info.plist"
    }
  }
}
